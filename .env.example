# Copy this file to .env and fill in your real values.
# .env is listed in .gitignore — never commit it to version control.

# Alpaca API credentials (get from https://app.alpaca.markets)
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here

# Kafka broker address (matches docker-compose.yml host port)
KAFKA_BROKER=localhost:29092

# Optional: comma-separated list of ticker symbols to stream
SYMBOLS=AAPL,TSLA,GOOGL,MSFT,AMZN
